generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id             Int      @id @default(autoincrement())
  admissionNumber String  @unique
  name           String
  course         String
  year           Int
  dateOfBirth    DateTime
  email          String
  mobileNumber   String
  gender         String
  address        String
  photoUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}